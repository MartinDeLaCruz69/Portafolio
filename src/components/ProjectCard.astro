---
const { title, description, tags, link, image, wip } = Astro.props;
---
<a href={link} target="_blank"
   class="group relative flex flex-col rounded-2xl border border-white/10 overflow-hidden bg-white/[0.03] hover:bg-white/[0.06] hover:border-white/20 transition-all duration-300 hover:-translate-y-1">

  <!-- Imagen del proyecto -->
  <div class="h-48 overflow-hidden bg-gray-900">
    <img src={image} alt={title}
         class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 opacity-80 group-hover:opacity-100" />
  </div>

  <div class="p-5 flex flex-col gap-3 flex-1">
    <div class="flex items-start justify-between gap-2">
      <h3 class="font-display font-bold text-lg leading-tight">{title}</h3>
      {wip && (
        <span class="shrink-0 text-xs px-2 py-0.5 rounded-full border"
              style="border-color: var(--accent); color: var(--accent)">WIP</span>
      )}
    </div>
    <p class="text-gray-400 text-sm leading-relaxed flex-1">{description}</p>
    <div class="flex flex-wrap gap-2 pt-1">
      {tags.map((tag) => (
        <span class="text-xs px-2.5 py-1 rounded-md bg-white/5 text-gray-400 font-mono">{tag}</span>
      ))}
    </div>
  </div>

  <!-- Arrow indicator -->
  <div class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color: var(--accent)">
      <line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/>
    </svg>
  </div>
</a>